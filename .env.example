# Copy to .env and adjust. .env is gitignored. just loads this file via set dotenv-load.
PGHOST=localhost
PGPORT=55432
PGUSER=mmm
PGPASSWORD=mmm
PGDATABASE=mmm

# Local checkout of bitcoin-data/mining-pools used by `just gen-pool-snapshot`.
# Set this in .env, or pass the path as the first recipe argument.
# MMM_POOLS_DIR=/path/to/mining-pools/pools

# Local historical dataset roots used by manifest generation and import-dataset.
# MERGE_MINING_RESEARCH_DIR=/path/to/merge-mining-research
# MERGE_MINING_ARCHIVE_DIR=/path/to/stale-blocks

# Namecoin Core JSON-RPC for the Namecoin AuxPoW poller.
NAMECOIN_RPC_URL=http://127.0.0.1:8336
NAMECOIN_RPC_USER=namecoinrpc
NAMECOIN_RPC_PASSWORD=change-me
# START_HEIGHT is an explicit replay/reset override. Leave it COMMENTED so live
# polling defaults to the chain tip (a fresh source seeds at tip - reorg_depth;
# an existing one resumes from its persisted poll_cursor row).
# NAMECOIN_START_HEIGHT=19200
NAMECOIN_POLL_INTERVAL_SECONDS=30
NAMECOIN_BATCH_SIZE=100
NAMECOIN_REORG_DEPTH=0
# Whole-request HTTP timeout (seconds). Default 15. Bounds a stalled connection
# so the tip fetch fails fast and retries instead of hanging the poll tick.
# NAMECOIN_RPC_TIMEOUT_SECS=15

# RSK (Rootstock) JSON-RPC for the RSK capture producer.
RSK_RPC_URL=http://127.0.0.1:4444
# Optional auth: leave COMMENTED unless RSKj requires it. just loads .env, so an
# empty RSK_RPC_USER= would become Some("") and trigger a basic_auth attempt; do
# not uncomment with blank values.
# RSK_RPC_USER=
# RSK_RPC_PASSWORD=
# Explicit replay/reset override; leave COMMENTED to default to the tip.
# RSK_START_HEIGHT=139999
RSK_POLL_INTERVAL_SECONDS=30
RSK_BATCH_SIZE=100
RSK_REORG_DEPTH=64
# Whole-request HTTP timeout (seconds). Default 15. See NAMECOIN note above.
# RSK_RPC_TIMEOUT_SECS=15

# Syscoin Core JSON-RPC for the Syscoin AuxPoW producer. User/password
# auth and cookie auth are alternatives; leave optional values commented unless
# needed.
SYSCOIN_RPC_URL=http://127.0.0.1:8370
# SYSCOIN_RPC_USER=
# SYSCOIN_RPC_PASSWORD=
# SYSCOIN_RPC_COOKIEFILE=/path/to/syscoin/.cookie
# Explicit replay/reset override; leave COMMENTED to default to the tip.
# SYSCOIN_START_HEIGHT=1973
SYSCOIN_POLL_INTERVAL_SECONDS=30
SYSCOIN_BATCH_SIZE=100
SYSCOIN_REORG_DEPTH=0
# Whole-request HTTP timeout (seconds). Default 15. See NAMECOIN note above.
# SYSCOIN_RPC_TIMEOUT_SECS=15

# Fractal Bitcoin JSON-RPC for the Fractal AuxPoW producer. The producer
# reads the merge-mining proof via `getblockheader <hash> false true`, NOT
# `getblock 0` (Fractal's raw block carries no inline CAuxPow). User/password and
# cookie auth are alternatives; from_env BAILS if only one of user/password is
# set, so leave them commented TOGETHER here and set BOTH in your local .env if
# your node requires auth.
FRACTAL_RPC_URL=http://127.0.0.1:18332
# FRACTAL_RPC_USER=
# FRACTAL_RPC_PASSWORD=
# FRACTAL_RPC_COOKIEFILE=/path/to/fractal/.cookie
# Explicit replay/reset override; leave COMMENTED to default to the tip.
# FRACTAL_START_HEIGHT=1
FRACTAL_POLL_INTERVAL_SECONDS=30
FRACTAL_BATCH_SIZE=100
FRACTAL_REORG_DEPTH=0
# Whole-request HTTP timeout (seconds). Default 15. See NAMECOIN note above.
# FRACTAL_RPC_TIMEOUT_SECS=15

# --- Hathor (public REST API; whitelist-permissioned network, no local node) ---
# Capture self-verifies the BTC evidence (RFC 0006 reconstruction + Hath marker
# + BTC PoW + offline nBits verdict), so no auth is needed for the public REST.
HATHOR_RPC_URL=https://node1.mainnet.hathor.network/v1a
# Second endpoint tried after the primary exhausts retries; set empty to disable.
# HATHOR_RPC_FALLBACK_URL=https://node2.mainnet.hathor.network/v1a
# Explicit replay/reset override; leave COMMENTED to default to the tip.
# HATHOR_START_HEIGHT=1000000
HATHOR_POLL_INTERVAL_SECONDS=30
HATHOR_BATCH_SIZE=100
# Trailing rescan window for child-DAG voids/replacements (~30s blocks).
HATHOR_REORG_DEPTH=20
# HATHOR_RPC_TIMEOUT_SECS=15
# Bounded backfill safeguards (the public REST API must not be swept):
# HATHOR_MAX_BACKFILL_RANGE=5000
# HATHOR_ALLOW_LARGE_BACKFILL=1
# HATHOR_RPC_BACKFILL_DELAY_MS=200
# HATHOR_BACKFILL_SKIP_HOLDS=1

# --- Elastos (ELA; self-hosted node or public RPC) ---
# Set ELASTOS_RPC_URL to your node's address. For a LAN-direct deployment use
# the form http://<node-host>:20336 when that node is configured to
# admit the monitor host. The stock build only honors loopback, so an untweaked
# node needs an SSH tunnel.
# Public drop-in fallback (same JSON-RPC shape): https://api.elastos.io/ela .
# Capture self-verifies the BTC evidence on either endpoint (full CAuxPow
# commitment + BTC parent-target + child-target gates + offline nBits verdict).
ELASTOS_RPC_URL=http://127.0.0.1:20336
# Optional basic auth (set both or neither).
# ELASTOS_RPC_USER=
# ELASTOS_RPC_PASSWORD=
# Explicit replay/reset override; leave COMMENTED to default to the tip. Also the
# backfill->live handoff: boot ONCE with ELASTOS_START_HEIGHT=<backfill_end + 1>
# to persist the live cursor, then remove it.
# ELASTOS_START_HEIGHT=177000
ELASTOS_POLL_INTERVAL_SECONDS=30
ELASTOS_BATCH_SIZE=100
# No ELASTOS_REORG_DEPTH: Elastos is monotonic (DPoS finality) and a present
# value is REJECTED (a trailing rescan needs same-height reconciliation, a
# deferred follow-up).
# ELASTOS_RPC_TIMEOUT_SECS=15
# Bounded backfill safeguards. The range cap applies on EITHER endpoint (a full
# 177000..tip backfill needs the override); the per-request delay is the public
# endpoint throttle (leave 0 for the local node).
# ELASTOS_MAX_BACKFILL_RANGE=50000
# ELASTOS_ALLOW_LARGE_BACKFILL=1
# ELASTOS_RPC_BACKFILL_DELAY_MS=200

# Bitcoin Core JSON-RPC for the optional on-demand parent classifier. When
# BITCOIN_RPC_URL is unset the classifier is Disabled and BTC-PoW-valid parents
# stay 'unknown' (no canonical/stale). Point at a synced, ideally archival node
# so historical stale parents resolve.
BITCOIN_RPC_URL=http://127.0.0.1:8332
# Optional auth: leave COMMENTED unless Core requires it. from_env BAILS if only
# one of user/pass is set or either is empty; do not uncomment with blanks.
# BITCOIN_RPC_USER=
# BITCOIN_RPC_PASSWORD=
# Must be > 15s (corepc-client transport headroom).
BITCOIN_RPC_TIMEOUT_SECS=30
BITCOIN_RPC_MAX_CONCURRENCY=4
# Follow-mode Bitcoin Core backbone knobs. The live window must be at least the
# default 16-block tree window; lower it only when throttling Core and stop-grace
# latency matters.
# BITCOIN_CORE_SYNC_FOLLOW_INTERVAL_SECS=60
# BITCOIN_CORE_SYNC_LIVE_WINDOW_HEIGHTS=64
# BITCOIN_CORE_SYNC_DELAY_MS=0

# Read API `serve` subcommand. The DB connection reuses the PG* vars above.
SERVE_BIND_ADDR=127.0.0.1:8080
SERVE_WWW_DIR=www
SERVE_DB_POOL_SIZE=8
